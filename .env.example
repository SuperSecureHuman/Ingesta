# HLS POC Configuration

# Media paths
MEDIA_ROOT=/

# Transcoding
SEGMENT_LENGTH=6

# Database (SQLite or PostgreSQL)
# SQLite: sqlite+aio:///./data/hls_poc.db
# PostgreSQL: postgresql+asyncpg://user:password@localhost/hls_poc
DATABASE_URL=sqlite+aio:///./data/hls_poc.db

# Server
MAX_CONCURRENT_STREAMS=10

# Security
SECRET_KEY=change-me-in-production
ADMIN_API_KEY=change-me-in-production

# Background tasks
SCANNER_INTERVAL=30
CLEANUP_INTERVAL=20
WORKDIR_CLEANUP_INTERVAL=300
WORKDIR_RETENTION_SECONDS=3600
SEGMENT_RETENTION_SECONDS=120

# Logging
LOG_LEVEL=INFO
